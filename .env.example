# Copy this file to .env and adjust values as needed.
# The app reads these at startup via config/settings.py.

# ── Data column mappings ───────────────────────────────────────────────────────
DATE_COL=Cal_Month
TARGET_COL=clicks
SPEND_COL=media_spend
CHANNEL_COL=site
DATE_FORMAT=%Y-%m-%d

# ── MCMC settings ─────────────────────────────────────────────────────────────
ADSTOCK_MAX_LAG=4
MCMC_DRAWS=1000
MCMC_TUNE=500
MCMC_CHAINS=2
MCMC_TARGET_ACCEPT=0.9
RANDOM_SEED=42

# ── Optimisation defaults ──────────────────────────────────────────────────────
DEFAULT_BUDGET=100000
MIN_CHANNEL_SHARE=0.05
MAX_CHANNEL_SHARE=0.60
N_SCENARIOS=3

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
OUTPUT_DIR=outputs
